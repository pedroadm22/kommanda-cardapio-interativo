
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-node"
}

model Restaurant {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique // ex: barraca-do-peixe
  products  Product[]
  tables    Table[]
}

model Table {
  id           String   @id @default(uuid())
  number       Int      // Número da mesa
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  orders       Order[]
}

model Product {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  imageUrl     String?
  category     String   // ex: Bebidas, Petiscos, Pratos Principais
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Order {
  id         String      @id @default(uuid())
  tableId    String
  table      Table       @relation(fields: [tableId], references: [id])
  items      Json        // Lista de produtos e quantidades
  total      Float
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  PREPARING
  DELIVERED
  PAID
}